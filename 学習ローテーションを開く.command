#!/bin/bash
# このファイルをダブルクリックすると、学習ローテーションのアプリが
# ローカルサーバー(http://localhost)経由でブラウザに開きます。
#
# ※ YouTubeの埋め込み動画は file:// では再生できない(エラー153)ため、
#   この方式で開く必要があります。
# ※ 表示されたターミナルのウィンドウは、アプリを使っている間は
#   開いたままにしてください。閉じるとサーバーが止まります。

cd "$(dirname "$0")"
PORT=8765

# 1秒待ってからブラウザを開く（サーバー起動を待つため）
( sleep 1; open "http://localhost:${PORT}/index.html" ) &

echo "学習ローテーションを起動しました。"
echo "ブラウザが自動で開きます。"
echo ""
echo "▼ 使い終わったら、このウィンドウを閉じてください（サーバーが止まります）。"
echo ""

python3 -m http.server "${PORT}"
